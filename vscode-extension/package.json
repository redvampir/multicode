{
  "$schema": "../schemas/package.schema.json",
  "name": "multicode-visual-programming",
  "displayName": "МультиКод - Visual Programming",
  "description": "Визуальное программирование для C++ — Blueprint-редактор с генерацией кода и поддержкой русского языка",
  "version": "0.4.1",
  "publisher": "multicode-team",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/redvampir/multicode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Programming Languages",
    "Visualization",
    "Education"
  ],
  "keywords": [
    "visual programming",
    "blueprints",
    "C++",
    "Rust",
    "Assembly",
    "graph",
    "low-level",
    "Russian"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:cpp",
    "onLanguage:rust",
    "onCommand:multicode.openEditor",
    "onCommand:multicode.newGraph",
    "onCommand:multicode.saveGraph",
    "onCommand:multicode.loadGraph",
    "onCommand:multicode.generateCode",
    "onCommand:multicode.translateGraph"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "multicode.openEditor",
        "title": "МультиКод: Open Visual Editor",
        "icon": "$(graph)"
      },
      {
        "command": "multicode.generateCode",
        "title": "МультиКод: Generate Code",
        "icon": "$(code)"
      },
      {
        "command": "multicode.newGraph",
        "title": "МультиКод: New Graph",
        "icon": "$(new-file)"
      },
      {
        "command": "multicode.saveGraph",
        "title": "МультиКод: Save Graph",
        "icon": "$(save)"
      },
      {
        "command": "multicode.loadGraph",
        "title": "МультиКод: Load Graph",
        "icon": "$(folder-opened)"
      },
      {
        "command": "multicode.translateGraph",
        "title": "МультиКод: Перевести граф (Marian)",
        "icon": "$(globe)"
      }
    ],
    "keybindings": [
      {
        "command": "multicode.openEditor",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == cpp || editorLangId == rust"
      },
      {
        "command": "multicode.generateCode",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "multicode.openEditor",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "navigation@1"
        },
        {
          "command": "multicode.newGraph",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "navigation@2"
        },
        {
          "command": "multicode.loadGraph",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "navigation@3"
        },
        {
          "command": "multicode.saveGraph",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "navigation@4"
        },
        {
          "command": "multicode.generateCode",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "navigation@5"
        },
        {
          "command": "multicode.translateGraph",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "navigation@6"
        }
      ],
      "editor/context": [
        {
          "command": "multicode.openEditor",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "multicode@1"
        },
        {
          "command": "multicode.newGraph",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "multicode@2"
        },
        {
          "command": "multicode.loadGraph",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "multicode@3"
        },
        {
          "command": "multicode.saveGraph",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "multicode@4"
        },
        {
          "command": "multicode.generateCode",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "multicode@5"
        },
        {
          "command": "multicode.translateGraph",
          "when": "editorLangId == cpp || editorLangId == rust",
          "group": "multicode@6"
        }
      ]
    },
    "configuration": {
      "title": "МультиКод",
      "properties": {
        "multicode.language": {
          "type": "string",
          "enum": [
            "cpp",
            "rust",
            "asm"
          ],
          "default": "cpp",
          "description": "Target programming language"
        },
        "multicode.displayLanguage": {
          "type": "string",
          "enum": [
            "ru",
            "en"
          ],
          "default": "ru",
          "description": "Node display language"
        },
        "multicode.theme": {
          "type": "string",
          "enum": [
            "dark",
            "light",
            "auto"
          ],
          "default": "auto",
          "description": "Visual editor theme"
        },
        "multicode.aiNaming.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-powered node naming"
        },
        "multicode.codegen.autoGenerate": {
          "type": "boolean",
          "default": false,
          "description": "Automatically generate code on graph change"
        },
        "multicode.codegen.verboseLogs": {
          "type": "boolean",
          "default": false,
          "description": "Show detailed [CodeGen] diagnostics in Output channel"
        },
        "multicode.codegen.outputProfile": {
          "type": "string",
          "enum": [
            "clean",
            "learn",
            "debug",
            "recovery"
          ],
          "default": "clean",
          "description": "Generated C++ output profile: clean (minimal), learn (readable comments), debug (node markers), recovery (debug + embedded snapshot)"
        },
        "multicode.cpp.standard": {
          "type": "string",
          "enum": [
            "cpp14",
            "cpp17",
            "cpp20",
            "cpp23"
          ],
          "default": "cpp23",
          "description": "C++ standard for Compile & Run (Run is always strict C++23)"
        },
        "multicode.cpp.toolchain.mode": {
          "type": "string",
          "enum": [
            "auto",
            "system",
            "managed"
          ],
          "default": "auto",
          "description": "Toolchain selection mode for Compile & Run"
        },
        "multicode.cpp.toolchain.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install a managed toolchain if no suitable system C++23 compiler is found"
        },
        "multicode.cpp.toolchain.installLocation": {
          "type": "string",
          "enum": [
            "global",
            "workspace"
          ],
          "default": "global",
          "description": "Where to install the managed toolchain"
        },
        "multicode.cpp.toolchain.downloadConsent": {
          "type": "string",
          "enum": [
            "once",
            "always",
            "never"
          ],
          "default": "once",
          "description": "Ask for permission to download toolchain binaries"
        },
        "multicode.cpp.toolchain.managedVersionChannel": {
          "type": "string",
          "enum": [
            "pinned"
          ],
          "default": "pinned",
          "description": "Managed toolchain version channel"
        },
        "multicode.graphBinding.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Связывать исходники с .multicode-файлами через комментарий @multicode:graph"
        },
        "multicode.graphBinding.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "Автосохранять привязанный .multicode при изменениях графа"
        },
        "multicode.graphBinding.folder": {
          "type": "string",
          "default": ".multicode",
          "description": "Папка для .multicode (относительно корня workspace). Можно указать абсолютный путь."
        },
        "multicode.graphBinding.maxLines": {
          "type": "number",
          "default": 10,
          "minimum": 4,
          "maximum": 200,
          "description": "Сколько первых строк исходника сканировать в поиске @multicode:graph"
        },
        "multicode.translation.engine": {
          "type": "string",
          "enum": [
            "none",
            "marian"
          ],
          "default": "none",
          "description": "Включить офлайн-перевод через MarianMT"
        },
        "multicode.translation.model.ruEn": {
          "type": "string",
          "default": "Helsinki-NLP/opus-mt-ru-en",
          "description": "Модель MarianMT для перевода RU→EN"
        },
        "multicode.translation.model.enRu": {
          "type": "string",
          "default": "Helsinki-NLP/opus-mt-en-ru",
          "description": "Модель MarianMT для перевода EN→RU"
        },
        "multicode.translation.cacheLimit": {
          "type": "number",
          "default": 200,
          "minimum": 50,
          "description": "Размер кэша переводов MarianMT"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts,tsx",
    "test": "node ./out/test/runTest.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/cytoscape": "^3.21.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^18.0.0",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.22",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vscode/test-electron": "^2.3.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^24.1.0",
    "mocha": "^10.2.0",
    "prettier": "^3.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "@types/dagre": "^0.7.53",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "@xenova/transformers": "^2.17.2",
    "@xyflow/react": "^12.10.0",
    "cytoscape": "^3.26.0",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-klay": "^3.1.4",
    "dagre": "^0.8.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.23.8",
    "zustand": "^4.4.0"
  }
}
